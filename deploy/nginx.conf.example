# /etc/nginx/sites-available/demos.yourdomain.com
#
# Run `certbot --nginx -d demos.yourdomain.com` afterwards to get HTTPS.
# Replace demos.yourdomain.com with your actual subdomain.

server {
    listen 80;
    listen [::]:80;
    server_name demos.yourdomain.com;

    # Body size: bumped only because /api may take small JSON; demos are git-cloned, no uploads.
    client_max_body_size 2m;

    # ---- Admin UI + API proxied to the Node app ----
    location /admin {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # ---- Redirect bare "/<slug>" to "/<slug>/" so relative asset paths resolve ----
    location ~ ^/([a-z0-9][a-z0-9-]{0,38}[a-z0-9]?)$ {
        return 301 /$1/;
    }

    # ---- Serve demo static files ----
    # /var/www/demos/<slug>/... is built and synced by the host tool.
    # Hidden dirs (.disabled, .staging-*, .trash-*) are internal — block them.
    location ~ ^/\. {
        return 404;
    }

    location / {
        root /var/www/demos;

        # SPA fallback: try the requested file, then fall back to that slug's index.html.
        # Captures the first path segment and falls back to <slug>/index.html.
        try_files $uri $uri/ @spa_fallback;

        # Caching: hashed assets get long cache, index.html stays fresh.
        location ~* \.(js|css|woff2?|ttf|otf|eot|png|jpe?g|gif|svg|webp|avif|ico|mp4|webm)$ {
            root /var/www/demos;
            try_files $uri =404;
            expires 30d;
            add_header Cache-Control "public, max-age=2592000, immutable";
        }
    }

    location @spa_fallback {
        # Extract the first path segment as the slug and serve its index.html.
        rewrite ^/([^/]+)(?:/.*)?$ /$1/index.html last;
    }

    # Default landing if no slug given.
    location = / {
        return 302 /admin/;
    }

    # Block top-level index.html lookup with no slug.
    location = /index.html {
        return 404;
    }
}
