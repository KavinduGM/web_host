# Port for the admin API/UI server (nginx proxies /admin and /api here)
PORT=3001

# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# bcrypt hash of the single admin password.
# Generate with: node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
ADMIN_PASSWORD_HASH=

# Absolute path where active demo builds are served from by nginx.
DEMOS_DIR=/var/www/demos

# Absolute path where disabled demos are parked (still on disk, not served).
DISABLED_DIR=/var/www/demos/.disabled

# Working directory for git clones and builds (scratch space).
WORK_DIR=/var/lib/web-host-tool/work

# Public base URL of the hosting tool (used to display demo links in the UI).
PUBLIC_BASE_URL=https://demos.yourdomain.com

# Path to the SQLite database file.
DB_PATH=/var/lib/web-host-tool/data.db

# Max concurrent builds.
BUILD_CONCURRENCY=1
